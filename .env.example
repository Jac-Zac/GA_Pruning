# Copy to .env and fill in. .env is gitignored.

# Root directory for the dataset, checkpoint, and three result JSON files.
# Defaults to ./artifacts if unset.
# On HPC clusters point this at the fast scratch partition so nothing hits the home fs:
#   Orfeo:  ARTIFACTS_DIR=/orfeo/scratch/dssc/`username`/gamo
ARTIFACTS_DIR=./artifacts
